{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge Agent",
  "version": "0.1.0",
  "identifier": "dev.forge.agent",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Forge Agent",
        "width": 460,
        "height": 600,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; connect-src 'none'; font-src 'self'; form-action 'none'; frame-ancestors 'none'; img-src 'self' asset: http://asset.localhost; object-src 'none'; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "externalBin": ["binaries/forge-agent"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "nsis": null,
      "wix": null
    },
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
